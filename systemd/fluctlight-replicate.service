[Unit]
Description=FluctlightDB WAL replication tail (primary → replica)
After=network.target fluctlight-serve.service
Wants=fluctlight-serve.service

[Service]
Type=simple
User=fluctlight
Group=fluctlight
EnvironmentFile=/etc/fluctlight/environment
Environment=FLUCTLIGHT_STORAGE=v4
Environment=FLUCTLIGHT_REPLICA_INTERVAL_SEC=2
ExecStart=/bin/sh -ec 'exec "$FLUCTLIGHT_INSTALL/scripts/replicate.sh"'
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
