{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": ".cursor/hooks/session_start.py",
        "timeout": 15
      }
    ],
    "sessionEnd": [
      {
        "command": ".cursor/hooks/session_end.py",
        "timeout": 15
      }
    ],
    "stop": [
      {
        "command": ".cursor/hooks/stop_handoff.py",
        "timeout": 20
      }
    ]
  }
}
