{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "{{session_start_hook}}",
        "timeout": 15
      }
    ],
    "sessionEnd": [
      {
        "command": "{{session_end_hook}}",
        "timeout": 15
      }
    ],
    "stop": [
      {
        "command": "{{stop_handoff_hook}}",
        "timeout": 20
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "{{before_submit_hook}}",
        "timeout": 12
      }
    ],
    "postToolUse": [
      {
        "command": "{{track_files_hook}}",
        "matcher": "Write|Edit",
        "timeout": 10
      }
    ]
  }
}
